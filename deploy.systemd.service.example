[Unit]
Description=Python Web UI Request Tester
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/python-webui-3-token-import-argparse
Environment=PYTHONUNBUFFERED=1
Environment=REQUEST_TESTER_HOST=127.0.0.1
Environment=REQUEST_TESTER_PORT=8765
ExecStart=/opt/python-webui-3-token-import-argparse/.venv/bin/python server.py --host 127.0.0.1 --port 8765
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
